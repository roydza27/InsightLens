<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/spacing_md"
    android:paddingEnd="@dimen/spacing_md"
    android:paddingTop="@dimen/spacing_md"
    android:paddingBottom="@dimen/spacing_md"
    android:background="@color/card_background">

    <!-- Icon background -->
    <FrameLayout
        android:id="@+id/setting_icon_bg"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_icon_circle_blue"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/setting_icon"
            android:layout_width="@dimen/icon_medium"
            android:layout_height="@dimen/icon_medium"
            android:layout_gravity="center"
            android:src="@drawable/ic_settings"
            android:contentDescription=""
            app:tint="@color/primary_blue" />
    </FrameLayout>

    <!-- Title -->
    <TextView
        android:id="@+id/setting_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Setting Title"
        style="@style/Text.TitleMedium"
        android:textSize="15sp"
        android:layout_marginStart="@dimen/spacing_md"
        app:layout_constraintStart_toEndOf="@id/setting_icon_bg"
        app:layout_constraintEnd_toStartOf="@+id/setting_arrow"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/setting_subtitle" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/setting_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Subtitle"
        style="@style/Text.Caption"
        android:layout_marginStart="@dimen/spacing_md"
        android:visibility="gone"
        app:layout_constraintStart_toEndOf="@id/setting_icon_bg"
        app:layout_constraintEnd_toStartOf="@+id/setting_arrow"
        app:layout_constraintTop_toBottomOf="@+id/setting_title"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Arrow / External link icon -->
    <ImageView
        android:id="@+id/setting_arrow"
        android:layout_width="@dimen/icon_small"
        android:layout_height="@dimen/icon_small"
        android:src="@drawable/ic_chevron_right"
        android:contentDescription=""
        app:tint="@color/text_secondary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>