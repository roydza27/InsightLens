<?xml version="1.0" encoding="utf-8"?>
<!-- TASK 25: Root is NestedScrollView -->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_gray"
    android:fillViewport="true">

    <!-- TASK 26: Vertical container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top bar background wrapper -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/background_white">

            <!-- TASK 27: Include top bar -->
            <include layout="@layout/component_topbar" />

        </LinearLayout>

        <!-- Content area with spacing -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/spacing_md"
            android:paddingEnd="@dimen/spacing_md"
            android:paddingTop="@dimen/spacing_lg"
            android:paddingBottom="@dimen/spacing_md"
            android:background="@color/background_white">

            <!-- TASK 28: Welcome text -->
            <TextView
                android:id="@+id/home_welcome_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/welcome_back"
                style="@style/Text.TitleLarge"
                android:textSize="24sp" />

            <TextView
                android:id="@+id/home_welcome_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_subtitle"
                style="@style/Text.Subtitle"
                android:layout_marginTop="@dimen/spacing_xs" />

            <!-- TASK 29: Quick Scan Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/home_quick_scan_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                app:cardCornerRadius="@dimen/corner_large"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/primary_blue">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <!-- TASK 30: Quick scan title -->
                    <TextView
                        android:id="@+id/home_scan_card_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/quick_scan"
                        style="@style/Text.TitleMedium"
                        android:textColor="@android:color/white"
                        android:textSize="22sp" />

                    <!-- TASK 31: Quick scan description -->
                    <TextView
                        android:id="@+id/home_scan_card_desc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/quick_scan_desc"
                        style="@style/Text.Body"
                        android:textColor="#CCffffff"
                        android:textSize="14sp"
                        android:layout_marginTop="@dimen/spacing_sm" />

                    <!-- TASK 32: Scan button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/home_start_scan_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/start_scan"
                        android:backgroundTint="@color/background_white"
                        android:textColor="@color/primary_blue"
                        android:layout_marginTop="@dimen/spacing_md"
                        app:cornerRadius="@dimen/corner_large"
                        app:icon="@drawable/ic_scan"
                        app:iconTint="@color/primary_blue"
                        app:iconGravity="textStart" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- TASK 33: Tip card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/home_tip_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                app:cardCornerRadius="@dimen/corner_large"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/tip_card_bg"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="@dimen/spacing_md">

                    <!-- TASK 34: Tip icon -->
                    <FrameLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_icon_circle_blue">

                        <ImageView
                            android:layout_width="@dimen/icon_medium"
                            android:layout_height="@dimen/icon_medium"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_lightbulb"
                            android:contentDescription=""
                            app:tint="@color/primary_blue" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="@dimen/spacing_md">

                        <!-- TASK 35: Tip title -->
                        <TextView
                            android:id="@+id/home_tip_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/tip_of_day"
                            style="@style/Text.TitleMedium"
                            android:textSize="15sp" />

                        <!-- TASK 36: Tip description -->
                        <TextView
                            android:id="@+id/home_tip_desc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/tip_desc"
                            style="@style/Text.Body"
                            android:textSize="13sp"
                            android:layout_marginTop="@dimen/spacing_xs" />

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- Section header area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="@dimen/spacing_sm"
            android:background="@color/background_white"
            android:paddingTop="@dimen/spacing_md"
            android:paddingBottom="@dimen/spacing_sm">

            <!-- TASK 37: Section header using component_section_header -->
            <include
                android:id="@+id/home_section_header"
                layout="@layout/component_section_header" />

            <!-- TASK 38: Horizontal RecyclerView for recent scans -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/home_recent_recycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="@dimen/spacing_md"
                android:paddingEnd="@dimen/spacing_md"
                android:paddingBottom="@dimen/spacing_md"
                android:clipToPadding="false"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>