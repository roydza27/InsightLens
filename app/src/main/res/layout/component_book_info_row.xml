<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/spacing_md"
    android:paddingEnd="@dimen/spacing_md"
    android:paddingTop="@dimen/spacing_sm"
    android:paddingBottom="@dimen/spacing_sm">

    <!-- Row icon -->
    <ImageView
        android:id="@+id/book_info_icon"
        android:layout_width="@dimen/icon_small"
        android:layout_height="@dimen/icon_small"
        android:src="@drawable/ic_book_info"
        android:contentDescription=""
        app:tint="@color/text_secondary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Label -->
    <TextView
        android:id="@+id/book_info_label"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Label"
        style="@style/Text.Body"
        android:textSize="14sp"
        android:layout_marginStart="@dimen/spacing_sm"
        app:layout_constraintStart_toEndOf="@id/book_info_icon"
        app:layout_constraintEnd_toStartOf="@+id/book_info_value"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Value -->
    <TextView
        android:id="@+id/book_info_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Value"
        style="@style/Text.TitleMedium"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>