<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/spacing_md"
    android:paddingEnd="@dimen/spacing_md"
    android:paddingTop="@dimen/spacing_md"
    android:paddingBottom="@dimen/spacing_md"
    android:background="@color/card_background">

    <!-- Icon background circle -->
    <FrameLayout
        android:id="@+id/toggle_icon_bg"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_icon_circle_blue"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Icon -->
        <ImageView
            android:id="@+id/toggle_icon"
            android:layout_width="@dimen/icon_medium"
            android:layout_height="@dimen/icon_medium"
            android:layout_gravity="center"
            android:src="@drawable/ic_person"
            android:contentDescription=""
            app:tint="@color/primary_blue" />
    </FrameLayout>

    <!-- Title -->
    <TextView
        android:id="@+id/toggle_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Toggle Title"
        style="@style/Text.TitleMedium"
        android:textSize="15sp"
        android:layout_marginStart="@dimen/spacing_md"
        app:layout_constraintStart_toEndOf="@id/toggle_icon_bg"
        app:layout_constraintEnd_toStartOf="@+id/toggle_switch"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Switch -->
    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/toggle_switch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:thumbTint="@color/background_white"
        app:trackTint="@color/switch_track_selector" />

</androidx.constraintlayout.widget.ConstraintLayout>