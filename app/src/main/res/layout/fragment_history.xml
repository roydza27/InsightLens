<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_gray">

    <!-- Main content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top bar - consistent with component_topbar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/topbar_height"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/spacing_sm"
            android:paddingEnd="@dimen/spacing_sm"
            android:background="@color/background_white">

            <ImageView
                android:id="@+id/history_back_btn"
                android:layout_width="@dimen/icon_button_size"
                android:layout_height="@dimen/icon_button_size"
                android:src="@drawable/ic_arrow_back"
                android:padding="@dimen/spacing_sm"
                android:scaleType="center"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/back"
                app:tint="@color/text_primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/scan_history"
                style="@style/Text.TitleMedium"
                android:textSize="20sp"
                android:layout_marginStart="@dimen/spacing_xs" />

            <ImageView
                android:id="@+id/history_search_btn"
                android:layout_width="@dimen/icon_button_size"
                android:layout_height="@dimen/icon_button_size"
                android:src="@drawable/ic_search"
                android:padding="@dimen/spacing_sm"
                android:scaleType="center"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/search"
                app:tint="@color/text_primary" />

        </LinearLayout>

        <!-- Tab layout -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/history_tabs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/background_white"
            app:tabSelectedTextColor="@color/primary_blue"
            app:tabTextColor="@color/text_secondary"
            app:tabIndicatorColor="@color/primary_blue"
            app:tabIndicatorHeight="2dp"
            app:tabMode="scrollable"
            app:tabGravity="start">

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/all_scans" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/books" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/articles" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/documents" />

        </com.google.android.material.tabs.TabLayout>

        <!-- History RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/history_recycler"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingStart="@dimen/spacing_md"
            android:paddingEnd="@dimen/spacing_md"
            android:paddingTop="@dimen/spacing_md"
            android:paddingBottom="80dp"
            android:clipToPadding="false"
            android:background="@color/light_gray"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        <!-- Empty state -->
        <TextView
            android:id="@+id/history_empty_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="24dp"
            android:paddingBottom="24dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="@string/no_history_scans"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:gravity="center"
            android:visibility="gone" />

    </LinearLayout>

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/history_fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/spacing_lg"
        android:layout_gravity="bottom|end"
        android:src="@drawable/ic_scan"
        android:contentDescription="@string/scan"
        app:backgroundTint="@color/primary_blue"
        app:tint="@android:color/white"
        app:fabSize="normal" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>