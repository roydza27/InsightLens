<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_bg">

    <!-- Decorative bottom background image -->
    <ImageView
        android:id="@+id/splash_bg_image"
        android:layout_width="0dp"
        android:layout_height="220dp"
        android:src="@drawable/bg_splash_arch"
        android:scaleType="centerCrop"
        android:contentDescription=""
        android:alpha="0.6"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Logo image — positioned at 38% from top -->
    <ImageView
        android:id="@+id/splash_logo"
        android:layout_width="@dimen/logo_size"
        android:layout_height="@dimen/logo_size"
        android:src="@drawable/ic_logo_book"
        android:background="@drawable/bg_logo_splash"
        android:padding="@dimen/spacing_lg"
        android:contentDescription="@string/app_name"
        android:scaleType="fitCenter"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVerticalBias="0.35" />

    <!-- App title -->
    <TextView
        android:id="@+id/splash_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        style="@style/Text.TitleLarge"
        android:textSize="36sp"
        android:layout_marginTop="@dimen/spacing_lg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/splash_logo" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/splash_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/splash_subtitle"
        style="@style/Text.Subtitle"
        android:layout_marginTop="@dimen/spacing_sm"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/splash_title" />

    <!-- Status text -->
    <TextView
        android:id="@+id/splash_status_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/splash_preparing"
        style="@style/Text.Body"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        android:layout_marginTop="@dimen/spacing_xl"
        android:layout_marginStart="@dimen/spacing_xl"
        android:layout_marginEnd="@dimen/spacing_xl"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/splash_percent"
        app:layout_constraintTop_toBottomOf="@+id/splash_subtitle" />

    <!-- Percentage text -->
    <TextView
        android:id="@+id/splash_percent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="35%"
        style="@style/Text.Body"
        android:textColor="@color/primary_blue"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginEnd="@dimen/spacing_xl"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/splash_status_text"
        app:layout_constraintBottom_toBottomOf="@+id/splash_status_text" />

    <!-- Progress bar -->
    <ProgressBar
        android:id="@+id/splash_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="@dimen/progress_bar_height"
        android:max="100"
        android:progress="35"
        android:progressTint="@color/primary_blue"
        android:progressBackgroundTint="@color/divider"
        android:layout_marginTop="@dimen/spacing_sm"
        android:layout_marginStart="@dimen/spacing_xl"
        android:layout_marginEnd="@dimen/spacing_xl"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/splash_status_text" />

    <!-- AI powered badge at bottom -->
    <LinearLayout
        android:id="@+id/splash_ai_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="@dimen/spacing_xl"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="@dimen/icon_small"
            android:layout_height="@dimen/icon_small"
            android:src="@drawable/ic_lightning"
            android:contentDescription=""
            android:layout_marginEnd="@dimen/spacing_xs" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/splash_ai_powered"
            style="@style/Text.Body"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>