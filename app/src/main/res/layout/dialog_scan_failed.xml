<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="@drawable/bg_dialog"
    android:padding="@dimen/spacing_xl">

    <ImageView
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="@drawable/bg_icon_circle"
        android:padding="@dimen/spacing_md"
        android:src="@drawable/ic_warning"
        android:contentDescription="" />

    <TextView
        style="@style/Text.TitleMedium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        android:text="@string/scan_failed_title"
        android:textSize="18sp"
        android:gravity="center" />

    <!-- ID used by ScanFragment to set the error message -->
    <TextView
        android:id="@+id/dialog_description"
        style="@style/Text.Body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        android:text="@string/scan_failed_desc"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:gravity="center"
        android:lineSpacingMultiplier="1.4" />

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_marginTop="@dimen/spacing_lg"
        android:background="@drawable/bg_drag_handle" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_lg"
        android:orientation="horizontal">

        <Button
            android:id="@+id/dialog_dismiss_btn"
            style="@style/SecondaryButton"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/spacing_sm"
            android:text="@string/dismiss" />

        <Button
            android:id="@+id/dialog_retry_btn"
            style="@style/PrimaryButton"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_sm"
            android:text="@string/retry_scan" />

    </LinearLayout>

</LinearLayout>